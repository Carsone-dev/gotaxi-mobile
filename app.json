{
  "expo": {
    "name": "GoTaxi",
    "slug": "gotaxi",
    "scheme": "gotaxi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#009542"
    },
    "ios": {
      "bundleIdentifier": "bj.gotaxi.app",
      "supportsTablet": false,
      "config": {
        "googleMapsApiKey": "REMPLACER_PAR_VOTRE_CLE_API_GOOGLE_MAPS"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GoTaxi a besoin de votre position pour vous trouver des trajets proches",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "GoTaxi a besoin de votre position pour la navigation GPS pendant le trajet",
        "NSCameraUsageDescription": "Pour photographier vos colis et documents",
        "NSPhotoLibraryUsageDescription": "Pour ajouter une photo de profil ou de colis",
        "UIBackgroundModes": ["location"]
      }
    },
    "android": {
      "package": "bj.gotaxi.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#009542"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "REMPLACER_PAR_VOTRE_CLE_API_GOOGLE_MAPS"
        }
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "GoTaxi a besoin de votre position pour la navigation GPS"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://192.168.1.101:8001/api/v1",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
