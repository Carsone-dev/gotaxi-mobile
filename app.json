{
  "expo": {
    "name": "GoTaxi",
    "slug": "gotaxi",
    "scheme": "gotaxi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#009542"
    },
    "ios": {
      "bundleIdentifier": "bj.gotaxi.app",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "GoTaxi a besoin de votre position pour vous trouver des trajets proches",
        "NSCameraUsageDescription": "Pour photographier vos colis et documents",
        "NSPhotoLibraryUsageDescription": "Pour ajouter une photo de profil ou de colis"
      }
    },
    "android": {
      "package": "bj.gotaxi.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#009542"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-localization",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "http://192.168.1.101:8001/api/v1",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
